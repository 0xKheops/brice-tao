# === Chain Connection ===
# WebSocket endpoint(s) for Bittensor RPC nodes (comma-separated for failover)
WS_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443,wss://bittensor-finney.api.onfinality.io/public-ws,wss://bittensor.public.blastapi.io

# === Wallet ===
# Your coldkey SS58 address (the account that owns the TAO)
COLDKEY_ADDRESS=

# Proxy account mnemonic (12 or 24 words)
# This account will sign transactions on behalf of coldkey
# SECURITY: Never share this mnemonic!
PROXY_MNEMONIC=

# Your preferred validator hotkey SS58 address
VALIDATOR_HOTKEY=5FtBncJvGhxjBs4aFn2pid6aur9tBUuo9QR7sHe5DkoRizzo

# === Notifications ===
# Discord webhook URL for alerts
# Create at: Server Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=

SN45_API_KEY=

# === Scheduling (Docker only) ===
CRON_SCHEDULE=0 */12 * * *
