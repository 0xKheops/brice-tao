# === Chain Connection ===
# WebSocket endpoint(s) for Bittensor RPC nodes (comma-separated for failover)
WS_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443,wss://bittensor-finney.api.onfinality.io/public-ws,wss://bittensor.public.blastapi.io

# Optional: Archive node endpoint for historical price warmup (comma-separated for failover)
# Enables instant indicator computation on startup instead of waiting for samples to accumulate
# Used by strategies that need historical price data (e.g., sma-stoploss)
ARCHIVE_WS_ENDPOINT=

# === Wallet ===
# Your coldkey SS58 address (the account that owns the TAO — starts with "5")
COLDKEY_ADDRESS=

# Proxy account mnemonic (12 or 24 words)
# This account will sign transactions on behalf of coldkey
# SECURITY: Never share this mnemonic!
PROXY_MNEMONIC=

# Optional: fallback validator hotkey (SS58 address, starts with "5")
# Used only when dynamic yield-based validator selection fails
VALIDATOR_HOTKEY=

# === Notifications (optional) ===
# Discord webhook URL for rebalance alerts and error notifications
# Create at: Server Settings -> Integrations -> Webhooks
# If not set, the bot runs silently (logs only)
DISCORD_WEBHOOK_URL=

# === Strategy ===
# Active strategy name (overridden by --strategy CLI flag)
# Available: root-emission, copy-trade, sma-stoploss
STRATEGY=root-emission

# Leader coldkey address to mirror (only used by the copy-trade strategy)
LEADER_ADDRESS=
