{
	"name": "brice-tao",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"check": "biome check --error-on-warnings",
		"check:fix": "biome check --fix --error-on-warnings",
		"knip": "knip",
		"test": "bun test",
		"test:failures": "bun test --only-failures",
		"test:watch": "bun test --watch",
		"typecheck": "tsc --noEmit",
		"prepare": "simple-git-hooks",
		"generate-clients": "echo 'No API clients to generate'",
		"balances": "bun run scripts/show-balances.ts",
		"backfill": "bun run scripts/backfill-history.ts",
		"backtest": "bun run scripts/backtest.ts",
		"bunker": "bun run scripts/bunker.ts",
		"preview": "bun run scripts/preview-rebalance.ts",
		"rebalance": "bun run src/main.ts",
		"scheduler": "bun run src/scheduler.ts",
		"docker:build": "./scripts/dc.sh build",
		"docker:run": "./scripts/dc.sh up -d --build",
		"postinstall": "papi"
	},
	"simple-git-hooks": {
		"pre-commit": "bunx biome check --staged --no-errors-on-unmatched --error-on-warnings"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"knip": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"trustedDependencies": [
		"@polkadot-api/descriptors"
	],
	"dependencies": {
		"@noble/ciphers": "^2.1.1",
		"@polkadot-api/descriptors": "file:.papi/descriptors",
		"@polkadot-labs/hdkd": "^0.0.26",
		"@polkadot-labs/hdkd-helpers": "^0.0.27",
		"@polkadot/util": "^14.0.2",
		"@polkadot/util-crypto": "^14.0.2",
		"croner": "^10.0.1",
		"drizzle-orm": "^0.45.2",
		"mlkem": "^2.7.0",
		"polkadot-api": "2.0.0-rc.5",
		"rxjs": "^7.8.0",
		"yaml": "^2.8.3"
	}
}
